# Google OAuth credentials
# Create at https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth redirect URI — set to your Cloud Run URL in production
# e.g. https://cliptrimmer-abc123-uc.a.run.app/auth/callback
REDIRECT_URI=http://localhost:8080/auth/callback

# Random secret key (used for session signing)
SECRET_KEY=change-me-to-a-random-string
